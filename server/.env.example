# MongoDB connection string (get from MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/spliteasy?retryWrites=true&w=majority

# JWT secret (generate a random string: openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Server port
PORT=3000

# Environment
NODE_ENV=development

{
  "name": "spliteasy-mobile",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "test": "jest"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "expo": "~52.0.0",
    "expo-asset": "~10.0.0",
    "expo-camera": "~16.0.0",
    "expo-constants": "~17.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.3",
    "react-native-qrcode-svg": "^6.3.2",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0",
    "react-native-svg": "15.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@testing-library/react-native": "^12.4.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "react-test-renderer": "^18.3.1"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.[jt]sx?$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(jest-)?react-native|@react-native|@react-navigation|expo|expo-camera|expo-constants|expo-secure-store|expo-status-bar|@expo|react-native-svg|react-native-qrcode-svg|react-native-safe-area-context|react-native-screens)/"
    ],
    "moduleNameMapper": {
      "\\.(png|jpg|jpeg|gif|svg)$": "<rootDir>/__mocks__/fileMock.js",
      "^react-native$": "<rootDir>/__mocks__/react-native.js",
      "^react-native/(.*)$": "<rootDir>/__mocks__/react-native.js"
    },
    "moduleFileExtensions": [
      "ios.js",
      "js",
      "ios.jsx",
      "jsx",
      "ts",
      "tsx",
      "json",
      "node"
    ],
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ]
  }
}

{
  "name": "spliteasy-mobile",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "test": "jest --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.[jt]sx?$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|@react-native-community|expo|@expo|jest-expo|@unimodules|react-navigation|@react-navigation)/)"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "moduleNameMapper": {
      "^expo-image-picker$": "<rootDir>/src/__mocks__/expo-image-picker.js",
      "^react-native$": "<rootDir>/src/__mocks__/react-native.js",
      "^@testing-library/react-native$": "<rootDir>/src/__mocks__/@testing-library/react-native.js"
    },
    "setupFiles": [
      "<rootDir>/src/__mocks__/setup.js"
    ]
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "expo": "~52.0.0",
    "expo-asset": "~10.0.0",
    "expo-constants": "~17.0.0",
    "expo-image-picker": "^55.0.13",
    "expo-secure-store": "~14.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.3",
    "react-native-qrcode-svg": "^6.3.2",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0",
    "react-native-svg": "15.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "babel-jest": "^30.3.0",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.11",
    "react-test-renderer": "^18.3.1"
  }
}
